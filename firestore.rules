rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    function isAdmin() {
      return request.auth != null && 
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }
    
    match /menu_items/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }
    match /categories/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }
    match /orders/{id} {
      allow read: if isAdmin() || 
        request.auth.uid == resource.data.customerId ||
        request.auth.token.email == resource.data.customerEmail;
      allow create: if true; // guests can place orders
      allow update: if isAdmin();
    }
    match /users/{uid} {
      allow read, write: if request.auth.uid == uid || isAdmin();
    }
    match /reviews/{id} {
      allow read: if resource.data.isApproved == true || isAdmin();
      allow create: if request.auth != null;
      allow update, delete: if isAdmin();
    }
    match /site_config/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }
  }
}
